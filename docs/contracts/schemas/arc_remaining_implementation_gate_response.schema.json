{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema://arc-bot/remaining-implementation-gate-response",
  "title": "Arc Bot Remaining Implementation Gate Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "operator_console_server_state_owner",
    "guardian_owned_local_model_executor_boundary"
  ],
  "properties": {
    "operator_console_server_state_owner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "canonical_contract_family",
        "authoritative_fields",
        "arc_bot_may_consume",
        "arc_bot_must_not_do"
      ],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "canonical_contract_family": { "type": "string", "minLength": 1 },
        "authoritative_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "arc_bot_may_consume": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "arc_bot_must_not_do": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "guardian_owned_local_model_executor_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "canonical_contract_family",
        "required_guardian_inputs",
        "required_verifier_evidence_outputs",
        "arc_bot_may_consume",
        "arc_bot_must_not_do"
      ],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "canonical_contract_family": { "type": "string", "minLength": 1 },
        "required_guardian_inputs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "required_verifier_evidence_outputs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "arc_bot_may_consume": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "arc_bot_must_not_do": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
