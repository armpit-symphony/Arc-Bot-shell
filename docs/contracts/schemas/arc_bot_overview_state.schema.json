{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Arc Bot Overview State",
  "type": "object",
  "required": [
    "surface",
    "display_state_only",
    "envelope",
    "worker_summary",
    "queue_summary",
    "approval_summary",
    "incident_summary",
    "connector_health",
    "connector_readiness_posture",
    "model_route_posture",
    "metadata_actions",
    "blocked_actions",
    "live_model_inference_allowed",
    "tool_execution_allowed"
  ],
  "properties": {
    "surface": { "const": "overview" },
    "display_state_only": { "const": true },
    "envelope": {
      "type": "object",
      "required": [
        "tenant_id",
        "customer_context_id",
        "environment",
        "operator_role",
        "view_id",
        "view_type",
        "view_mode",
        "status",
        "policy_refs",
        "evidence_refs",
        "related_contract_refs",
        "runbook_refs"
      ],
      "properties": {
        "tenant_id": { "type": "string" },
        "customer_context_id": { "type": "string" },
        "environment": { "type": "string" },
        "operator_role": { "type": "string" },
        "view_id": { "type": "string" },
        "view_type": { "const": "overview" },
        "view_mode": { "type": "string" },
        "status": { "type": "string" },
        "policy_refs": { "type": "array", "items": { "type": "string" } },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "related_contract_refs": { "type": "array", "items": { "type": "string" } },
        "runbook_refs": { "type": "array", "items": { "type": "string" } },
        "future_lima_office_supervisor_seam": { "type": "string" },
        "future_lima_ai_os_seam": { "type": "string" }
      },
      "additionalProperties": true
    },
    "worker_summary": { "type": "object" },
    "queue_summary": { "type": "object" },
    "approval_summary": { "type": "object" },
    "incident_summary": { "type": "object" },
    "connector_health": { "type": "object" },
    "connector_readiness_posture": { "type": "string" },
    "model_route_posture": { "type": "object" },
    "metadata_actions": { "type": "array", "items": { "type": "string" } },
    "blocked_actions": { "type": "array", "items": { "type": "string" } },
    "live_model_inference_allowed": { "type": "boolean" },
    "tool_execution_allowed": { "type": "boolean" },
    "credential_storage_allowed": { "type": "boolean" },
    "provider_token_storage_allowed": { "type": "boolean" },
    "raw_runtime_payload_persistence_allowed": { "type": "boolean" },
    "runtime_route_change_without_approval_allowed": { "type": "boolean" },
    "external_message_send_allowed": { "type": "boolean" },
    "customer_system_mutation_allowed": { "type": "boolean" },
    "live_program_execution_allowed": { "type": "boolean" }
  },
  "additionalProperties": true
}
