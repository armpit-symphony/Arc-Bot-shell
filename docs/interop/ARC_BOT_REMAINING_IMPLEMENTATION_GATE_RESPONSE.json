      "model.route refs",
      "evidence refs",
      "blocked execution posture",
      "local_model_bundle_ref.execution_enabled=false"
    ],
    "arc_bot_may_consume": [
      "model.route mock_only metadata",
      "model.route local_planned metadata",
      "Guardian decision refs",
      "evidence refs",
      "local_model_bundle_ref refs"
    ],
    "arc_bot_must_not_do": [
      "execute_local_inference",
      "call_ollama_qwen",
      "probe_endpoints",
      "treat_route_metadata_as_execution_authority",
      "enable_local_model_execution"
    ]
